# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
API_BASE_URL=https://YOUR-RAILWAY-URL.railway.app/privacyscan

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite (default — zero config, works immediately)
DATABASE_URL="file:./prisma/privacyscan.db"

# PostgreSQL (swap in when scaling to thousands of users)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/privacyscan"

# ─── PAYSTACK ─────────────────────────────────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Get from: dashboard.paystack.com → Settings → Webhooks
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=generate_a_64_char_random_hex_string_here

# ─── AFFILIATE ────────────────────────────────────────────────────────────────
AFFILIATE_COMMISSION_RATE=0.60
